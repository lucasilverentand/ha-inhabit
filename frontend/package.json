{
  "name": "ha-inhabit-frontend",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && BUILD_FROM_TSC=1 rollup -c",
    "watch": "rollup -c -w",
    "lint": "biome check src",
    "format": "biome check --fix src",
    "test": "web-test-runner",
    "test:coverage": "web-test-runner --coverage"
  },
  "dependencies": {
    "@preact/signals-core": "^1.5.0",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.5",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "rollup": "^4.9.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
